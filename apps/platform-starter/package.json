{
  "name": "@web-annotation/platform-starter",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsup --watch --onSuccess \"node dist/main.js\"",
