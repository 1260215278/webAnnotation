{
  "name": "@web-annotation/cli",
  "version": "0.1.0",
  "description": "Local CLI for previewing webAnnotation patch artifacts.",
  "license": "MIT",
  "author": "markss",
  "type": "module",
  "bin": {
    "web-annotation": "./dist/main.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "keywords": [
    "web-annotation",
    "cli",
    "patch",
    "diff",
    "annotation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1260215278/webAnnotation.git",
    "directory": "packages/annotation-cli"
  },
  "homepage": "https://github.com/1260215278/webAnnotation#readme",
  "bugs": {
    "url": "https://github.com/1260215278/webAnnotation/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
