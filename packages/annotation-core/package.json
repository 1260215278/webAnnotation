{
  "name": "@web-annotation/core",
  "version": "0.1.0",
  "description": "Browser runtime SDK for web annotation.",
  "license": "MIT",
  "author": "markss",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": [
    "web-annotation",
    "annotation",
    "feedback",
    "sdk",
    "browser",
    "dom",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1260215278/webAnnotation.git",
    "directory": "packages/annotation-core"
  },
  "homepage": "https://github.com/1260215278/webAnnotation#readme",
  "bugs": {
    "url": "https://github.com/1260215278/webAnnotation/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "jsdom": "^25.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
