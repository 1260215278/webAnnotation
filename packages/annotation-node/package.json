{
  "name": "@web-annotation/node",
  "version": "0.1.0",
  "description": "Node-side protocol kit: validate annotation payloads, resolve safe-mode sources, and build AI patch prompt context.",
  "license": "MIT",
  "author": "markss",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": [
    "web-annotation",
    "annotation",
    "protocol",
    "validation",
    "node",
    "ai",
    "patch"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1260215278/webAnnotation.git",
    "directory": "packages/annotation-node"
  },
  "homepage": "https://github.com/1260215278/webAnnotation#readme",
  "bugs": {
    "url": "https://github.com/1260215278/webAnnotation/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@web-annotation/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
