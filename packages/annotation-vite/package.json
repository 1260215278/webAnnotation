{
  "name": "@web-annotation/vite",
  "version": "0.1.0",
  "description": "Vite plugin that injects React source metadata for web annotation.",
  "license": "MIT",
  "author": "markss",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "keywords": [
    "web-annotation",
    "vite-plugin",
    "vite",
    "react",
    "source-metadata",
    "annotation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1260215278/webAnnotation.git",
    "directory": "packages/annotation-vite"
  },
  "homepage": "https://github.com/1260215278/webAnnotation#readme",
  "bugs": {
    "url": "https://github.com/1260215278/webAnnotation/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@babel/core": "^7.26.0",
    "@babel/types": "^7.26.0",
    "@web-annotation/core": "workspace:*"
  },
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
